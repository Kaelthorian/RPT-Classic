# Conservative editor defaults only; adding this file does not reformat existing files.
root = true

[*.dm]
indent_style = tab

[*.ps1]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 2

[.ignore]
indent_style = space
indent_size = 2

[.gitignore]
indent_style = space
indent_size = 2
